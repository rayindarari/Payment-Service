from fastapi import FastAPI, HTTPException
from pydantic import BaseModel
from typing import Optional
import uuid

app = FastAPI()

# Model data untuk validasi input
class PaymentRequest(BaseModel):
    user_id: str
    amount: float
    currency: str = "IDR"
    payment_method: str

# Simulasi database
payments_db = {}

@app.post("/payments/")
async def create_payment(payment: PaymentRequest):
    # Logika bisnis: Validasi sederhana
    if payment.amount <= 0:
        raise HTTPException(status_code=400, detail="Jumlah pembayaran harus lebih dari 0")
    
    # Membuat ID transaksi unik
    transaction_id = str(uuid.uuid4())
    
    # Simulasi memproses pembayaran
    payment_record = {
        "id": transaction_id,
        "user_id": payment.user_id,
        "amount": payment.amount,
        "status": "pending"  # Status awal
    }
    
    payments_db[transaction_id] = payment_record
    
    return {"message": "Pembayaran berhasil dibuat", "data": payment_record}

@app.get("/payments/{transaction_id}")
async def get_payment_status(transaction_id: str):
    if transaction_id not in payments_db:
        raise HTTPException(status_code=404, detail="Transaksi tidak ditemukan")
    return payments_db[transaction_id]
